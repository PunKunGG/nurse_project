  tmpText: {fileID: 676111996}
  lastKnownText: "\u0E2B\u0E0D\u0E34\u0E07\u0E44\u0E17\u0E22\u0E2D\u0E32\u0E22\u0E38
    68 \u0E1B\u0E35 \u0E2D\u0E32\u0E28\u0E31\u0E22\u0E2D\u0E22\u0E39\u0E48\u0E01\u0E31\u0E1A\u0E04\u0E23\u0E2D\u0E1A\u0E04\u0E23\u0E31\u0E27\u0E43\u0E19\u0E2B\u0E21\u0E39\u0E48\u0E1A\u0E49\u0E32\u0E19
    \r\n\u0E40\u0E04\u0E22\u0E04\u0E25\u0E2D\u0E14\u0E1A\u0E38\u0E15\u0E23\u0E17\u0E32\u0E07\u0E0A\u0E48\u0E2D\u0E07\u0E04\u0E25\u0E2D\u0E14
    4 \u0E04\u0E23\u0E31\u0E49\u0E07 \r\n\u0E21\u0E35\u0E42\u0E23\u0E04\u0E1B\u0E23\u0E30\u0E08\u0E33\u0E15\u0E31\u0E27\u0E40\u0E1B\u0E47\u0E19\u0E04\u0E27\u0E32\u0E21\u0E14\u0E31\u0E19\u0E42\u0E25\u0E2B\u0E34\u0E15\u0E2A\u0E39\u0E07\u0E41\u0E25\u0E30\u0E40\u0E1A\u0E32\u0E2B\u0E27\u0E32\u0E19\u0E0B\u0E36\u0E48\u0E07\u0E04\u0E27\u0E1A\u0E04\u0E38\u0E21\u0E44\u0E14\u0E49\u0E1B\u0E32\u0E19\u0E01\u0E25\u0E32\u0E07
    \r\n\u0E0A\u0E48\u0E27\u0E07 3 \u0E1B\u0E35\u0E17\u0E35\u0E48\u0E1C\u0E48\u0E32\u0E19\u0E21\u0E32\u0E40\u0E23\u0E34\u0E48\u0E21\u0E2A\u0E31\u0E07\u0E40\u0E01\u0E15\u0E27\u0E48\u0E32\u0E21\u0E31\u0E01\u0E21\u0E35\u0E1B\u0E31\u0E2A\u0E2A\u0E32\u0E27\u0E30\u0E40\u0E25\u0E47\u0E14\u0E2D\u0E2D\u0E01\u0E21\u0E32\u0E17\u0E35\u0E25\u0E30\u0E19\u0E49\u0E2D\u0E22\u0E40\u0E27\u0E25\u0E32\u0E21\u0E35\u0E44\u0E2D\u0E41\u0E23\u0E07
    \u0E46 \r\n\u0E2B\u0E31\u0E27\u0E40\u0E23\u0E32\u0E30\u0E40\u0E2A\u0E35\u0E22\u0E07\u0E14\u0E31\u0E07
    \u0E2B\u0E23\u0E37\u0E2D\u0E22\u0E01\u0E02\u0E2D\u0E07\u0E02\u0E36\u0E49\u0E19\u0E23\u0E16\u0E40\u0E02\u0E47\u0E19\u0E44\u0E1B\u0E15\u0E25\u0E32\u0E14\r\n\u0E0A\u0E48\u0E27\u0E07
    6 \u0E40\u0E14\u0E37\u0E2D\u0E19\u0E2B\u0E25\u0E31\u0E07\u0E2D\u0E32\u0E01\u0E32\u0E23\u0E40\u0E1B\u0E47\u0E19\u0E1A\u0E48\u0E2D\u0E22\u0E02\u0E36\u0E49\u0E19\u0E08\u0E19\u0E15\u0E49\u0E2D\u0E07\u0E43\u0E2A\u0E48\u0E1C\u0E49\u0E32\u0E2D\u0E19\u0E32\u0E21\u0E31\u0E22\u0E17\u0E31\u0E49\u0E07\u0E27\u0E31\u0E19
    \r\n\u0E40\u0E1B\u0E25\u0E35\u0E48\u0E22\u0E19\u0E27\u0E31\u0E19\u0E25\u0E30\u0E2B\u0E25\u0E32\u0E22\u0E41\u0E1C\u0E48\u0E19
    \u0E15\u0E2D\u0E19\u0E01\u0E25\u0E32\u0E07\u0E04\u0E37\u0E19\u0E08\u0E30\u0E15\u0E37\u0E48\u0E19\u0E21\u0E32\u0E1B\u0E31\u0E2A\u0E2A\u0E32\u0E27\u0E30
    1 \u0E04\u0E23\u0E31\u0E49\u0E07 \r\n\u0E42\u0E14\u0E22\u0E17\u0E31\u0E48\u0E27\u0E44\u0E1B\u0E21\u0E31\u0E01\u0E44\u0E21\u0E48\u0E40\u0E25\u0E47\u0E14\u0E02\u0E13\u0E30\u0E19\u0E2D\u0E19
    \u0E40\u0E14\u0E34\u0E19\u0E44\u0E14\u0E49\u0E40\u0E2D\u0E07 \u0E44\u0E21\u0E48\u0E15\u0E49\u0E2D\u0E07\u0E43\u0E0A\u0E49\u0E40\u0E04\u0E23\u0E37\u0E48\u0E2D\u0E07\u0E0A\u0E48\u0E27\u0E22\u0E40\u0E14\u0E34\u0E19
    \r\n\u0E01\u0E32\u0E23\u0E23\u0E31\u0E1A\u0E23\u0E39\u0E49\u0E41\u0E25\u0E30\u0E04\u0E27\u0E32\u0E21\u0E08\u0E33\u0E22\u0E31\u0E07\u0E1B\u0E01\u0E15\u0E34\u0E14\u0E35
    \r\n\u0E41\u0E15\u0E48\u0E40\u0E23\u0E34\u0E48\u0E21\u0E23\u0E39\u0E49\u0E2A\u0E36\u0E01\u0E2D\u0E32\u0E22\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E19\u0E40\u0E27\u0E25\u0E32\u0E02\u0E36\u0E49\u0E19\u0E25\u0E07\u0E1A\u0E31\u0E19\u0E44\u0E14\u0E44\u0E1B\u0E27\u0E31\u0E14
    \u0E40\u0E1E\u0E23\u0E32\u0E30\u0E01\u0E25\u0E31\u0E27\u0E08\u0E30\u0E21\u0E35\u0E01\u0E25\u0E34\u0E48\u0E19\u0E1B\u0E31\u0E2A\u0E2A\u0E32\u0E27\u0E30\u0E15\u0E34\u0E14\u0E15\u0E31\u0E27
    \r\n\u0E08\u0E36\u0E07\u0E15\u0E31\u0E14\u0E2A\u0E34\u0E19\u0E43\u0E08\u0E21\u0E32\u0E1B\u0E23\u0E36\u0E01\u0E29\u0E32\u0E40\u0E08\u0E49\u0E32\u0E2B\u0E19\u0E49\u0E32\u0E17\u0E35\u0E48
    \u0E23\u0E1E.\u0E2A\u0E15. \u0E43\u0E01\u0E25\u0E49\u0E1A\u0E49\u0E32\u0E19\u0E42\u0E14\u0E22\u0E21\u0E35
    \u0E2D\u0E2A\u0E21. \u0E1E\u0E32\u0E21\u0E32 \r\n"
  outputString: "\u0E2B\u0E0D\u0E34\u0E07\u200B\u0E44\u0E17\u0E22\u200B\u0E2D\u0E32\u0E22\u0E38\u200B
    68 \u200B\u0E1B\u0E35\u200B \u200B\u0E2D\u0E32\u0E28\u0E31\u0E22\u200B\u0E2D\u0E22\u0E39\u0E48\u200B\u0E01\u0E31\u0E1A\u200B\u0E04\u0E23\u0E2D\u0E1A\u0E04\u0E23\u0E31\u0E27\u200B\u0E43\u0E19\u200B\u0E2B\u0E21\u0E39\u0E48\u0E1A\u0E49\u0E32\u0E19\u200B
    \r\n\u200B\u0E40\u0E04\u0E22\u200B\u0E04\u0E25\u0E2D\u0E14\u200B\u0E1A\u0E38\u0E15\u0E23\u200B\u0E17\u0E32\u0E07\u200B\u0E0A\u0E48\u0E2D\u0E07\u0E04\u0E25\u0E2D\u0E14\u200B
    4 \u200B\u0E04\u0E23\u0E31\u0E49\u0E07\u200B \r\n\u200B\u0E21\u0E35\u200B\u0E42\u0E23\u0E04\u0E1B\u0E23\u0E30\u0E08\u0E33\u0E15\u0E31\u0E27\u200B\u0E40\u0E1B\u0E47\u0E19\u0E04\u0E27\u0E32\u0E21\u200B\u0E14\u0E31\u0E19\u200B\u0E42\u0E25\u0E2B\u0E34\u0E15\u200B\u0E2A\u0E39\u0E07\u200B\u0E41\u0E25\u0E30\u200B\u0E40\u0E1A\u0E32\u0E2B\u0E27\u0E32\u0E19\u200B\u0E0B\u0E36\u0E48\u0E07\u200B\u0E04\u0E27\u0E1A\u0E04\u0E38\u0E21\u200B\u0E44\u0E14\u0E49\u200B\u0E1B\u0E32\u0E19\u0E01\u0E25\u0E32\u0E07\u200B
    \r\n\u200B\u0E0A\u0E48\u0E27\u0E07\u200B 3 \u200B\u0E1B\u0E35\u200B\u0E17\u0E35\u0E48\u0E1C\u0E48\u0E32\u0E19\u0E21\u0E32\u200B\u0E40\u0E23\u0E34\u0E48\u0E21\u200B\u0E2A\u0E31\u0E07\u0E40\u0E01\u0E15\u0E27\u0E48\u0E32\u200B\u0E21\u0E31\u0E01\u200B\u0E21\u0E35\u200B\u0E1B\u0E31\u0E2A\u0E2A\u0E32\u0E27\u0E30\u200B\u0E40\u0E25\u0E47\u0E14\u200B\u0E2D\u0E2D\u0E01\u0E21\u0E32\u200B\u0E17\u0E35\u0E25\u0E30\u0E19\u0E49\u0E2D\u0E22\u200B\u0E40\u0E27\u0E25\u0E32\u200B\u0E21\u0E35\u200B\u0E44\u0E2D\u200B\u0E41\u0E23\u0E07\u200B
    \u0E46 \r\n\u200B\u0E2B\u0E31\u0E27\u0E40\u0E23\u0E32\u0E30\u200B\u0E40\u0E2A\u0E35\u0E22\u0E07\u0E14\u0E31\u0E07\u200B
    \u200B\u0E2B\u0E23\u0E37\u0E2D\u200B\u0E22\u0E01\u200B\u0E02\u0E2D\u0E07\u0E02\u0E36\u0E49\u0E19\u200B\u0E23\u0E16\u0E40\u0E02\u0E47\u0E19\u200B\u0E44\u0E1B\u200B\u0E15\u0E25\u0E32\u0E14\u200B\r\n\u200B\u0E0A\u0E48\u0E27\u0E07\u200B
    6 \u200B\u0E40\u0E14\u0E37\u0E2D\u0E19\u200B\u0E2B\u0E25\u0E31\u0E07\u200B\u0E2D\u0E32\u0E01\u0E32\u0E23\u200B\u0E40\u0E1B\u0E47\u0E19\u200B\u0E1A\u0E48\u0E2D\u0E22\u200B\u0E02\u0E36\u0E49\u0E19\u200B\u0E08\u0E19\u200B\u0E15\u0E49\u0E2D\u0E07\u200B\u0E43\u0E2A\u0E48\u200B\u0E1C\u0E49\u0E32\u0E2D\u0E19\u0E32\u0E21\u0E31\u0E22\u200B\u0E17\u0E31\u0E49\u0E07\u0E27\u0E31\u0E19\u200B
    \r\n\u200B\u0E40\u0E1B\u0E25\u0E35\u0E48\u0E22\u0E19\u200B\u0E27\u0E31\u0E19\u200B\u0E25\u0E30\u200B\u0E2B\u0E25\u0E32\u0E22\u200B\u0E41\u0E1C\u0E48\u0E19\u200B
    \u200B\u0E15\u0E2D\u0E19\u0E01\u0E25\u0E32\u0E07\u0E04\u0E37\u0E19\u200B\u0E08\u0E30\u200B\u0E15\u0E37\u0E48\u0E19\u200B\u0E21\u0E32\u200B\u0E1B\u0E31\u0E2A\u0E2A\u0E32\u0E27\u0E30\u200B
    1 \u200B\u0E04\u0E23\u0E31\u0E49\u0E07\u200B \r\n\u200B\u0E42\u0E14\u0E22\u0E17\u0E31\u0E48\u0E27\u0E44\u0E1B\u200B\u0E21\u0E31\u0E01\u200B\u0E44\u0E21\u0E48\u200B\u0E40\u0E25\u0E47\u0E14\u200B\u0E02\u0E13\u0E30\u200B\u0E19\u0E2D\u0E19\u200B
    \u200B\u0E40\u0E14\u0E34\u0E19\u200B\u0E44\u0E14\u0E49\u200B\u0E40\u0E2D\u0E07\u200B
    \u200B\u0E44\u0E21\u0E48\u0E15\u0E49\u0E2D\u0E07\u200B\u0E43\u0E0A\u0E49\u200B\u0E40\u0E04\u0E23\u0E37\u0E48\u0E2D\u0E07\u0E0A\u0E48\u0E27\u0E22\u200B\u0E40\u0E14\u0E34\u0E19\u200B
    \r\n\u200B\u0E01\u0E32\u0E23\u0E23\u0E31\u0E1A\u0E23\u0E39\u0E49\u200B\u0E41\u0E25\u0E30\u200B\u0E04\u0E27\u0E32\u0E21\u0E08\u0E33\u200B\u0E22\u0E31\u0E07\u200B\u0E1B\u0E01\u0E15\u0E34\u200B\u0E14\u0E35\u200B
    \r\n\u200B\u0E41\u0E15\u0E48\u200B\u0E40\u0E23\u0E34\u0E48\u0E21\u200B\u0E23\u0E39\u0E49\u0E2A\u0E36\u0E01\u200B\u0E2D\u0E32\u0E22\u200B\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E19\u200B\u0E40\u0E27\u0E25\u0E32\u200B\u0E02\u0E36\u0E49\u0E19\u200B\u0E25\u0E07\u200B\u0E1A\u0E31\u0E19\u0E44\u0E14\u200B\u0E44\u0E1B\u200B\u0E27\u0E31\u0E14\u200B
    \u200B\u0E40\u0E1E\u0E23\u0E32\u0E30\u200B\u0E01\u0E25\u0E31\u0E27\u200B\u0E08\u0E30\u200B\u0E21\u0E35\u0E01\u0E25\u0E34\u0E48\u0E19\u200B\u0E1B\u0E31\u0E2A\u0E2A\u0E32\u0E27\u0E30\u200B\u0E15\u0E34\u0E14\u0E15\u0E31\u0E27\u200B
    \r\n\u200B\u0E08\u0E36\u0E07\u200B\u0E15\u0E31\u0E14\u0E2A\u0E34\u0E19\u0E43\u0E08\u200B\u0E21\u0E32\u0E1B\u200B\u0E23\u0E36\u0E01\u200B\u0E29\u0E32\u200B\u0E40\u0E08\u0E49\u0E32\u0E2B\u0E19\u0E49\u0E32\u0E17\u0E35\u0E48\u200B
    \u200B\u0E23\u0E1E\u200B.\u200B\u0E2A\u0E15\u200B. \u200B\u0E43\u0E01\u0E25\u0E49\u200B\u0E1A\u0E49\u0E32\u0E19\u200B\u0E42\u0E14\u0E22\u0E21\u0E35\u200B
    \u200B\u0E2D\u0E2A\u0E21\u200B. \u200B\u0E1E\u0E32\u0E21\u0E32\u200B \r\n"
