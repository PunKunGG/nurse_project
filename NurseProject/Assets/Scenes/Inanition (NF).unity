  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InanitionHotspot
  isCorrect: 1
  id: 
  highlightObj: {fileID: 635944746}
  tooltipText: 
  itemName: "\u0E40\u0E2B\u0E25\u0E49\u0E32 / \u0E41\u0E2D\u0E25\u0E01\u0E2D\u0E2E\u0E2D\u0E25\u0E4C"
  knowledgeMessage: "\u0E1A\u0E48\u0E07\u0E0A\u0E35\u0E49\u0E16\u0E36\u0E07\u0E1E\u0E24\u0E15\u0E34\u0E01\u0E23\u0E23\u0E21\u0E01\u0E32\u0E23\u0E14\u0E37\u0E48\u0E21\u0E41\u0E2D\u0E25\u0E01\u0E2D\u0E2E\u0E2D\u0E25\u0E4C
    \u0E0B\u0E36\u0E48\u0E07\u0E2A\u0E32\u0E21\u0E32\u0E23\u0E16\u0E25\u0E14\u0E04\u0E27\u0E32\u0E21\u0E2D\u0E22\u0E32\u0E01\u0E2D\u0E32\u0E2B\u0E32\u0E23\u0E41\u0E25\u0E30\u0E17\u0E33\u0E43\u0E2B\u0E49\u0E1A\u0E38\u0E04\u0E04\u0E25\u0E23\u0E31\u0E1A\u0E1B\u0E23\u0E30\u0E17\u0E32\u0E19\u0E2D\u0E32\u0E2B\u0E32\u0E23\u0E44\u0E14\u0E49\u0E19\u0E49\u0E2D\u0E22\u0E25\u0E07
    \u0E19\u0E2D\u0E01\u0E08\u0E32\u0E01\u0E19\u0E35\u0E49\u0E41\u0E2D\u0E25\u0E01\u0E2D\u0E2E\u0E2D\u0E25\u0E4C\u0E22\u0E31\u0E07\u0E23\u0E1A\u0E01\u0E27\u0E19\u0E01\u0E32\u0E23\u0E14\u0E39\u0E14\u0E0B\u0E36\u0E21\u0E2A\u0E32\u0E23\u0E2D\u0E32\u0E2B\u0E32\u0E23\u0E1A\u0E32\u0E07\u0E0A\u0E19\u0E34\u0E14\u0E43\u0E19\u0E23\u0E48\u0E32\u0E07\u0E01\u0E32\u0E22
    \u0E17\u0E33\u0E43\u0E2B\u0E49\u0E23\u0E48\u0E32\u0E07\u0E01\u0E32\u0E22\u0E44\u0E14\u0E49\u0E23\u0E31\u0E1A\u0E2A\u0E32\u0E23\u0E2D\u0E32\u0E2B\u0E32\u0E23\u0E44\u0E21\u0E48\u0E40\u0E1E\u0E35\u0E22\u0E07\u0E1E\u0E2D
    \u0E41\u0E25\u0E30\u0E40\u0E1E\u0E34\u0E48\u0E21\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E15\u0E48\u0E2D\u0E20\u0E32\u0E27\u0E30\u0E17\u0E38\u0E1E\u0E42\u0E20\u0E0A\u0E19\u0E32\u0E01\u0E32\u0E23
    \u0E07\u0E32\u0E19\u0E27\u0E34\u0E08\u0E31\u0E22\u0E43\u0E19\u0E1B\u0E23\u0E30\u0E0A\u0E32\u0E01\u0E23\u0E44\u0E17\u0E22\u0E1E\u0E1A\u0E27\u0E48\u0E32\u0E1E\u0E24\u0E15\u0E34\u0E01\u0E23\u0E23\u0E21\u0E01\u0E32\u0E23\u0E1A\u0E23\u0E34\u0E42\u0E20\u0E04\u0E41\u0E25\u0E30\u0E01\u0E32\u0E23\u0E14\u0E37\u0E48\u0E21\u0E41\u0E2D\u0E25\u0E01\u0E2D\u0E2E\u0E2D\u0E25\u0E4C\u0E21\u0E35\u0E04\u0E27\u0E32\u0E21\u0E2A\u0E31\u0E21\u0E1E\u0E31\u0E19\u0E18\u0E4C\u0E01\u0E31\u0E1A\u0E20\u0E32\u0E27\u0E30\u0E42\u0E20\u0E0A\u0E19\u0E32\u0E01\u0E32\u0E23\u0E41\u0E25\u0E30\u0E2A\u0E38\u0E02\u0E20\u0E32\u0E1E\u0E42\u0E14\u0E22\u0E23\u0E27\u0E21
    (\u0E08\u0E38\u0E11\u0E32\u0E20\u0E23\u0E13\u0E4C \u0E25\u0E34\u0E48\u0E21\u0E2A\u0E38\u0E27\u0E23\u0E23\u0E13\u0E21\u0E13\u0E35
    \u0E41\u0E25\u0E30\u0E04\u0E13\u0E30, 2563)"
