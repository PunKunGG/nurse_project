    \u0E21\u0E35\u0E2D\u0E32\u0E01\u0E32\u0E23\u0E0A\u0E32\u0E1B\u0E25\u0E32\u0E22\u0E21\u0E37\u0E2D\u0E1B\u0E25\u0E32\u0E22\u0E40\u0E17\u0E49\u0E32\u0E41\u0E1A\u0E1A\u0E40\u0E2A\u0E49\u0E19\u0E1B\u0E23\u0E30\u0E2A\u0E32\u0E17\u0E40\u0E2A\u0E37\u0E48\u0E2D\u0E21
